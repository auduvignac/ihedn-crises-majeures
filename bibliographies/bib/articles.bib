@article{DESAINTSALVY2026,
  title    = {Comment mobiliser les auditeurs de l'IHEDN ?},
  journal  = {Médecine de Catastrophe - Urgences Collectives},
  year     = {2026},
  issn     = {1279-8479},
  doi      = {https://doi.org/10.1016/j.pxur.2026.02.002},
  url      = {https://www.sciencedirect.com/science/article/pii/S1279847926000108},
  urldate  = {2026-05-03},
  author   = {Anne-François {de Saint Salvy}},
  keywords = {Réserve, Compétences, Reserve, Skills},
  abstract = {Résumé
              L'Institut des hautes études de défense nationale (IHEDN) assure à ses auditeurs une formation de haut niveau dans les différents domaines de la défense, que ce soit dans les sessions nationales, régionales ou pour les jeunes. Le but de cette formation est de permettre à ces auditeurs, militaires ou civils, d'être ensuite les promoteurs de l'esprit de défense dans la société et de concourir, à leur place et selon les besoins, à la défense et à la sécurité de notre pays. L'investissement que représente cette formation, en temps et en moyens, demande un retour sur investissement. La réponse à la question posée est donc une évidence : oui, les auditeurs de l'IHEDN ont un rôle à jouer pour appuyer les forces actives, qu'elles soient civiles ou militaires. La création d'une réserve de l'IHEDN a été étudiée à la demande d'Édouard Philippe, Premier ministre, dès 2018 après de premiers travaux en 2015 au sein de l'IHEDN. Structurée sur le modèle des réserves citoyennes des Armées et s'appuyant sur elles, cette réserve citoyenne de l'IHEDN n'a finalement pas vu le jour. Il est temps aujourd'hui de reprendre ce projet, sans doute d'une manière simplifiée et de se mettre en mesure de tirer profit des multiples compétences qu'apportent les auditeurs de l'IHEDN. Au-delà d'un statut et d‘une organisation, le premier pas est sans doute celui d'un recensement des compétences disponibles, inscrites dans une grille permettant de les utiliser efficacement et tenu à jour régulièrement. C'est un rôle que les associations d'anciens auditeurs, telles que l'AA-IHEDN et d'autres, pourraient assurer, apportant ainsi leur contribution à la mobilisation de ces compétences.
              Summary
              IHEDN (Institut des hautes études de défense nationale) provides its auditors with high-level training in the different fields of Defence, whether in national, regional or youth sessions. The purpose of this training is to allow auditors, military or civilian, to then be the promoters of the spirit of defence in society and to contribute, in their place and according to the needs, to the defence and security of our country. The investment that this training represents, in time and resources, requires a return on investment. Answering the question is therefore obvious: yes, IHEDN auditors have a role to play in supporting active forces, whether civilian or military. The creation of an IHEDN reserve was studied at the request of Édouard Philippe, Prime Minister, in 2018 after initial work in 2015 within IHEDN. Structured on the model of the citizen reserves of the armed forces and based on them, this citizen reserve of the IHEDN was not finally implemented. It is time today to resume this project, undoubtedly in a simplified manner and to take advantage of the multiple skills that IHEDN auditors bring. Beyond a status and an organization, the first step is undoubtedly that of a census of available skills, recorded in a grid allowing them to be used efficiently and kept up to date regularly. It is a role that associations of former listeners, such as the AA-IHEDN and others could ensure, thus contributing to the mobilization of these skills.},
  keywords     = {article_de_recherche}
}

